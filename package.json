{
  "name": "independence",
  "version": "1.0.0",
  "description": "Independence — The Turkish War of Independence, a Risk-style strategy game",
  "scripts": {
    "generate-map-data": "node scripts/generate-map-data.mjs",
    "start": "parcel src/index.html",
    "build": "parcel build src/index.html --dist-dir dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "test": "tsx --test test/*.test.ts",
    "train-ai": "tsx scripts/train-ai.ts",
    "eval-ai": "tsx scripts/eval-ai.ts",
    "eval-parallel": "tsx scripts/eval-parallel.ts",
    "test:watch": "tsx --test --watch test/*.test.ts",
    "sweep": "tsx scripts/balance-sweep.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "alias": {
    "@mermaid-js/parser": "./node_modules/@mermaid-js/parser/dist/mermaid-parser.core.mjs",
    "uuid": "./node_modules/uuid/dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@parcel/packager-raw-url": "^2.16.4",
    "@parcel/transformer-webmanifest": "^2.16.4",
    "@types/clipper-lib": "^6.4.0",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "buffer": "^6.0.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "parcel": "^2.16.4",
    "prettier": "^3.9.6",
    "process": "^0.11.10",
    "tsx": "^4.23.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.65.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "clipper-lib": "^6.4.2",
    "mermaid": "^11.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
